# ============================================================
# Loop 工程 · 唯一配置文件
# 套用到新项目时，你只需要改这一个文件。
# 格式：可被 bash source 的 KEY="value"。等号两边不要有空格。
# ============================================================

# --- 项目模式 ---
PROJECT_MODE="fullstack"   # frontend(纯前端) | backend(纯后端) | fullstack(前后端)

# --- 前端（PROJECT_MODE 含前端时必填）---
FE_LANG="<fe_lang>"        # 开发语言/框架，例: TypeScript + React / Vue3。generator/evaluator 据此遵循该生态习惯
FE_DIR="."                 # 前端代码目录。monorepo 如 apps/web；单目录填 .
FE_TEST_CMD="<fe_test>"    # 例: npm test
FE_LINT_CMD="<fe_lint>"    # 例: npm run lint
FE_BUILD_CMD="<fe_build>"  # 例: npm run build
FE_RUN_CMD="<fe_run>"      # 例: npm run dev  （评判器起前端服务、用浏览器验证）

# --- 后端（PROJECT_MODE 含后端时必填）---
BE_LANG="<be_lang>"        # 开发语言/框架，例: Python + FastAPI / Java + Spring Boot / Go + Gin
BE_DIR="."                 # 后端代码目录。monorepo 如 apps/api；单目录填 .
BE_TEST_CMD="<be_test>"    # 例: pytest  /  mvn test
BE_LINT_CMD="<be_lint>"    # 例: ruff check .
BE_BUILD_CMD="<be_build>"  # 例: mvn -q -DskipTests package
BE_RUN_CMD="<be_run>"      # 例: uvicorn app:app  （评判器起后端、发请求验证）

# --- 分支与自主档位 ---
MAIN_BRANCH="main"               # 主分支名
AUTO_MERGE="true"                # C档=true(评判通过即自动合并)；B档=false(只开PR等人)。改这一个值切换档位

# --- 验证与重试 ---
MAX_FIX_ATTEMPTS="3"             # 评判打回后，generator 最多重修几次

# --- 预算守卫（防 token 失控）---
PER_LOOP_BUDGET="200"            # 单圈最大工具调用次数
DAILY_BUDGET="2000"              # 每日最大工具调用次数
MAX_RETRIES="5"                  # 预留：单圈最大重试

# --- 外部连接（可选）---
MCP_CONFIG=""                    # 留空=不接外部系统；接 GitHub/issue/Slack/Playwright 时在 settings.json 配 MCP

# 注：
# - 纯前端模式只需填 FE_*，纯后端只填 BE_*，全栈两组都填。
# - 项目规约写在 CLAUDE.md，不放这里。
# - 前端评判靠浏览器（Playwright MCP）；后端评判靠 API/测试。详见 agents/evaluator.md。
