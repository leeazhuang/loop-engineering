# ============================================================
# Loop 工程 · 唯一配置文件
# 套用到新项目时，你只需要改这一个文件。
# 格式：可被 bash source 的 KEY="value"。等号两边不要有空格。
# ============================================================

# --- 项目命令（必填，换成你项目的真实命令）---
TEST_CMD="<test_command>"        # 例: npm test  /  pytest  /  mvn test
LINT_CMD="<lint_command>"        # 例: npm run lint  /  ruff check .
BUILD_CMD="<build_command>"      # 例: npm run build  /  mvn -q -DskipTests package
RUN_CMD="<run_command>"          # 例: npm start  （评判器动手验证用）

# --- 分支与自主档位 ---
MAIN_BRANCH="main"               # 主分支名
AUTO_MERGE="true"                # C档=true(评判通过即自动合并 MAIN_BRANCH)；B档=false(只开PR等人) —— 改这一个值即可切换档位

# --- 验证与重试 ---
MAX_FIX_ATTEMPTS="3"             # 评判打回后，generator 最多重修几次

# --- 预算守卫（防 token 失控）---
PER_LOOP_BUDGET="200"            # 单圈最大工具调用次数
DAILY_BUDGET="2000"              # 每日最大工具调用次数
MAX_RETRIES="5"                  # 预留：单圈最大重试

# --- 外部连接（可选）---
MCP_CONFIG=""                    # 留空=不接外部系统；接 GitHub/issue/Slack 时在 settings.json 配 MCP

# 注：项目规约（命名/分层/测试约定）写在 CLAUDE.md，不放这里（那是给模型读的自由文本）。
